import os
from flask import Flask
from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, ContextTypes

# Parte do Flask para o Render não dar erro
app = Flask(__name__)

@app.route('/')
def index():
    return "Bot is running"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await context.bot.send_message(chat_id=update.effective_chat.id, text="Opa! O bot de sinais está ativo!")

if __name__ == '__main__':
    # Configuração do Telegram
    # COLOQUE SEU TOKEN ABAIXO
    token = "SEU_TOKEN_AQUI"
    
    application = ApplicationBuilder().token(token).build()
    application.add_handler(CommandHandler('start', start))
    
    # Rodar o Flask e o Bot (Isso mantém o Render feliz)
    port = int(os.environ.get('PORT', 5000))
    # Note: Em deploy real, o ideal é usar Webhooks, mas para seguir o guia:
    application.run_polling()
    app.run(host='0.0.0.0', port=port)
